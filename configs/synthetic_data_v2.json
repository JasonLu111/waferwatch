{
  "schema_version": "2.0",
  "dataset_name": "WaferWatch Synthetic Data V2",
  "random_seed": 20260713,
  "provenance": {
    "base_dataset": "UCI SECOM",
    "input_path": "data/processed/secom_cleaned.csv",
    "disclosure": "Public UCI SECOM sensor data augmented with synthetic process context, event timelines, and root-cause ground truth for research use. It is not data from a real semiconductor fab."
  },
  "experiment_grid": {
    "anomaly_rates": [
      0.01,
      0.03,
      0.05,
      0.07
    ],
    "label_delay_hours": [
      12,
      24,
      48
    ],
    "unseen_context": {
      "enabled": true,
      "holdout_tools": [
        "TOOL_08"
      ],
      "holdout_chambers": [
        "TOOL_08_CH_02"
      ]
    }
  },
  "context": {
    "tools": [
      "TOOL_01",
      "TOOL_02",
      "TOOL_03",
      "TOOL_04",
      "TOOL_05",
      "TOOL_06",
      "TOOL_07",
      "TOOL_08"
    ],
    "chambers_per_tool": 2,
    "recipes": [
      "RCP_A",
      "RCP_B",
      "RCP_C"
    ],
    "product_families": [
      "LOGIC",
      "MEMORY",
      "MIXED_SIGNAL"
    ],
    "shifts": [
      "DAY",
      "SWING",
      "NIGHT"
    ]
  },
  "anomaly_mechanisms": [
    {
      "id": "abrupt_mean_shift",
      "enabled": true,
      "parameters": {
        "injection_rate": 0.03,
        "affected_sensor_fraction": [
          0.02,
          0.05
        ],
        "magnitude_sigma": [
          2.0,
          4.0
        ],
        "context_scope": [
          "tool_id",
          "chamber_id"
        ],
        "alarm_code": "ALARM_PRESSURE_SHIFT",
        "alarm_lead_hours": 2.0
      },
        "magnitude_sigma": [
          2.0,
          4.0
        ],
        "context_scope": [
          "tool_id",
          "chamber_id"
        ]
      },
    {
      "id": "gradual_degradation",
      "enabled": true,
      "parameters": {
      "injection_rate": 0.03,
      "affected_sensor_fraction": [
        0.02,
        0.05
      ],
      "degradation_window_lots": [
        20,
        80
      ],
      "maximum_magnitude_sigma": [
        1.5,
        3.5
      ],
      "requires_maintenance_delay": true,
      "maintenance_delay_days": [
        2,
        5
      ],
      "maintenance_type": "preventive_inspection",
      "component": "pressure_control_valve"
    }
    },
    {
      "id": "variance_instability",
      "enabled": true,
      "parameters": {
      "injection_rate": 0.03,
      "affected_sensor_fraction": [
        0.02,
        0.05
      ],
      "variance_multiplier": [
        1.5,
        3.0
      ],
      "preserve_approximate_mean": true,
      "alarm_code": "ALARM_PROCESS_VARIABILITY",
      "alarm_lead_hours": 1.0
    }
    },
    {
      "id": "sensor_fault",
      "enabled": true,
      "parameters": {
        "fault_types": [
          "stuck_at",
          "dropout",
          "missing_burst",
          "calibration_bias"
        ],
        "affected_sensor_count": [
          1,
          5
        ],
        "missing_burst_length_lots": [
          2,
          10
        ]
      }
    },
    {
      "id": "recipe_product_mix_drift",
      "enabled": true,
      "parameters": {
        "drift_types": [
          "recipe_mix_change",
          "product_mix_change",
          "tool_reassignment"
        ],
        "fault_probability": 0.0,
        "expected_behavior": "benign_distribution_shift"
      }
    },
    {
      "id": "contextual_anomaly",
      "enabled": true,
      "parameters": {
        "conditioning_fields": [
          "recipe_id",
          "product_family"
        ],
        "normal_in_one_context": true,
        "abnormal_in_another_context": true
      }
    }
  ],
  "timeline_rules": [
    {
      "id": "alarm_before_affected_lot",
      "relative_time_hours": [
        -6.0,
        -0.5
      ]
    },
    {
      "id": "maintenance_delay_before_degradation",
      "delay_days": [
        1,
        7
      ]
    },
    {
      "id": "recipe_change_before_mix_drift",
      "relative_time_hours": [
        -24.0,
        -1.0
      ]
    }
  ],
  "root_causes": [
    {
      "root_cause_id": "RC_PRESSURE_INSTABILITY",
      "mechanism": "abrupt_mean_shift",
      "is_fault": true
    },
    {
      "root_cause_id": "RC_COMPONENT_WEAR",
      "mechanism": "gradual_degradation",
      "is_fault": true
    },
    {
      "root_cause_id": "RC_PROCESS_VARIABILITY",
      "mechanism": "variance_instability",
      "is_fault": true
    },
    {
      "root_cause_id": "RC_SENSOR_HARDWARE",
      "mechanism": "sensor_fault",
      "is_fault": true
    },
    {
      "root_cause_id": "RC_BENIGN_MIX_CHANGE",
      "mechanism": "recipe_product_mix_drift",
      "is_fault": false
    },
    {
      "root_cause_id": "RC_RECIPE_CONTEXT_MISMATCH",
      "mechanism": "contextual_anomaly",
      "is_fault": true
    }
  ],
  "outputs": [
    {
      "id": "lots",
      "path": "data/synthetic/v2/synthetic_secom_v2.csv",
      "required_columns": [
        "lot_id",
        "source_row_id",
        "event_time",
        "tool_id",
        "chamber_id",
        "recipe_id",
        "product_family",
        "shift",
        "quality_label",
        "label_delay_hours",
        "label_available_at",
        "is_synthetic_anomaly",
        "anomaly_mechanism",
        "root_cause_id",
        "is_unseen_context",
        "split"
      ]
    },
    {
      "id": "tool_events",
      "path": "data/synthetic/v2/synthetic_tool_events.csv",
      "required_columns": [
        "event_id",
        "tool_id",
        "chamber_id",
        "alarm_code",
        "event_type",
        "start_time",
        "end_time",
        "severity",
        "related_lot_id",
        "evidence_id"
      ]
    },
    {
      "id": "maintenance",
      "path": "data/synthetic/v2/synthetic_maintenance.csv",
      "required_columns": [
        "maintenance_id",
        "tool_id",
        "chamber_id",
        "scheduled_at",
        "performed_at",
        "delay_days",
        "maintenance_type",
        "component",
        "replacement_performed",
        "related_lot_id",
        "evidence_id"
      ]
    },
    {
      "id": "process_changes",
      "path": "data/synthetic/v2/synthetic_process_changes.csv",
      "required_columns": [
        "change_id",
        "change_type",
        "tool_id",
        "chamber_id",
        "old_value",
        "new_value",
        "changed_at",
        "related_lot_id",
        "is_benign_drift",
        "evidence_id"
      ]
    },
    {
      "id": "rca_ground_truth",
      "path": "data/synthetic/v2/synthetic_rca_ground_truth.csv",
      "required_columns": [
        "case_id",
        "lot_id",
        "root_cause_id",
        "suspected_cause",
        "recommended_action",
        "outcome",
        "evidence_ids",
        "supports_abstention",
        "top3_acceptable_causes"
      ]
    }
  ],
  "quality_rules": {
    "require_unique_lot_id": true,
    "require_deterministic_generation": true,
    "require_evidence_for_anomalous_lots": true,
    "require_known_root_cause_for_injected_anomalies": true,
    "prevent_label_availability_leakage": true,
    "preserve_benign_drift_cases": true
  }
}