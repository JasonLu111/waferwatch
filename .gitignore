@"
# Python cache
__pycache__/
*.pyc

# Virtual environment
.venv/
venv/

# Jupyter
.ipynb_checkpoints/

# Environment variables
.env

# Data files
data/raw/*
data/interim/*
data/processed/*
data/synthetic/*

# Keep empty data folders
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/synthetic/.gitkeep

# Model artifacts
/models/
mlruns/
*.pkl
*.joblib

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
"@ | Set-Content .gitignore -Encoding UTF8

